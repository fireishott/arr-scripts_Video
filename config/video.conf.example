# arr-scripts_Video Configuration
# https://github.com/fireishott/arr-scripts_Video

# Enable the script
enableVideo="true"

# Where to save music videos (must be mounted in container)
videoPath="/mnt/musicvideos"

# Video container format (mkv or mp4)
videoContainer="mkv"

# Subtitle language (en, es, fr, etc.)
youtubeSubtitleLanguage="en"

# Only process artists with this Lidarr tag (optional)
# videoDownloadTag="music-videos"

# How often to run (15m, 1h, etc.)
videoScriptInterval="15m"
